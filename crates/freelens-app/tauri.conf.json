{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freelens Rust Prototype",
  "version": "0.1.0",
  "identifier": "dev.freelens.prototype",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Freelens Rust Prototype",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
